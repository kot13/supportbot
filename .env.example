# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/supportbot"

# Auth (seeded admin credentials; store only secrets in real .env)
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="change-me"

# Telegram (token is stored in DB by admin UI in v1)
# PUBLIC_BASE_URL="https://your-public-url.example"  # if using webhook behind a public URL

# Optional: protect webhook from non-Telegram traffic
# TELEGRAM_WEBHOOK_SECRET="change-me"
