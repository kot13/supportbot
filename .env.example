# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/supportbot"

# Docker (pgvector): after `docker compose up -d`
# DATABASE_URL="postgresql://supportbot:supportbot@localhost:5433/supportbot"

# Auth (seeded admin credentials; store only secrets in real .env)
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="change-me"

# Telegram (token is stored in DB by admin UI in v1)
# PUBLIC_BASE_URL="https://your-public-url.example"  # if using webhook behind a public URL

# Optional: protect webhook from non-Telegram traffic
# TELEGRAM_WEBHOOK_SECRET="change-me"

# OpenAI (required for bot Q&A / RAG)
OPENAI_API_KEY="sk-..."

# RAG tuning (optional)
# RAG_TOP_K=6
# RAG_MAX_DISTANCE=0.62
# CHAT_CONTEXT_LIMIT=10

# Optional: override bot @username for mention detection in tests
# TELEGRAM_BOT_USERNAME="your_bot"

# Base URL for relative documentation links in bot answers
# DOCS_BASE_URL="https://docs.inappstory.com"
